    <!-- Donations -->
    <string name="settings_donate">Waktiva উন্নয়নে সহায়তা করুন</string>
    <string name="donate_title">Waktiva-কে সহায়তা করুন</string>
    <string name="donate_header">Waktiva-কে সহায়তা করুন 🤍</string>
    <string name="donate_desc">কোনো বিজ্ঞাপন নেই।\nকোনো ট্র্যাকিং নেই।\nকোনো ডেটা বিক্রি নেই।\nশুধুমাত্র একটি সৎ এবং দরকারী অ্যাপ।\n\nWaktiva যদি আপনার দৈনিক ইবাদতে সহায়ক হয়…\nআপনি যদি এমন একটি অ্যাপের প্রশংসা করেন যা আপনার গোপনীয়তাকে সম্মান করে…\nআপনি যদি এর ডিজাইন, ফিচার এবং লাইসেন্সকৃত কনটেন্ট উন্নত করতে সাহায্য করতে চান…\n\nআপনি দানের মাধ্যমে এর উন্নয়নে সহায়তা করতে পারেন।\n\nপ্রতি প্রতিটি অবদান — ছোট বা বড় — সত্যিই পরিবর্তন আনে।\n\nWaktiva-কে সহজ, ব্যক্তিগত এবং বিজ্ঞাপন-মুক্ত রাখতে সাহায্য করার জন্য ধন্যবাদ।</string>
    <string name="donate_footer">🤲 আল্লাহ আপনাকে ইহকাল ও পরকালে এর উত্তম প্রতিদান দান করুন।</string>
