<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Sun Glow -->
    <path
        android:pathData="M54,48m-20,0a20,20 0,1 1,40 0a20,20 0,1 1,-40 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="48"
                android:gradientRadius="20"
                android:type="radial">
                <item android:color="#33FBBF24" android:offset="0.0" />
                <item android:color="#00FBBF24" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Main Sun (Rising Behind) -->
    <path
        android:pathData="M54,48m-14,0a14,14 0,1 1,28 0a14,14 0,1 1,-28 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="48"
                android:gradientRadius="14"
                android:type="radial">
                <item android:color="#FDE68A" android:offset="0.0" /> <!-- Light Yellow -->
                <item android:color="#FBBF24" android:offset="1.0" /> <!-- Golden Sun -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right Swoosh (Cloud Shadow/Depth) -->
    <path
        android:pathData="M80,38 C80,63 69,73 61,73 L57,73 L54,59 L59,59 C64,67 70,59 70,38 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="73"
                android:endX="80"
                android:endY="38"
                android:type="linear">
                <item android:color="#E2E8F0" android:offset="0.0" />
                <item android:color="#CBD5E1" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Left Swoosh (Main Cloud/Foreground) -->
    <path
        android:pathData="M28,38 C28,63 39,73 47,73 L51,73 L54,59 L49,59 C44,67 38,59 38,38 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="73"
                android:endX="28"
                android:endY="38"
                android:type="linear">
                <item android:color="#FFFFFF" android:offset="0.0" />
                <item android:color="#F8FAFC" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle Shine Accent -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.4"
        android:pathData="M42,42 C42,45 44,47 47,47 L49,47 L50,45 L48,45 C46,45 45,44 45,42 Z" />

</vector>
