<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Matte Deep Surface -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#553156"
                android:endColor="#553156"
                android:type="linear" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <!-- Subtle Top Rim Highlight (Physicality) -->
    <item android:bottom="1dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#1AFFFFFF" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <!-- Content Area Soft Glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="150dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#0DFFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="32dp" />
        </shape>
    </item>
</layer-list>