<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Cinematic Day-to-Night Atmosphere (Softer, Premium Transition) -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startY="0"
                android:endY="108"
                android:startX="54"
                android:endX="54"
                android:type="linear">

                <item android:offset="0.0" android:color="#AF56FA" /> <!-- Soft Indigo Twilight -->
                <item android:offset="0.6" android:color="#6F1FAF" /> <!-- Deep Atmospheric Blue -->
                <item android:offset="1.0" android:color="#370A5B" /> <!-- Rich Midnight Navy -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Celestial Nebula Glow (Refined Depth) -->
    <path
        android:pathData="M54,80m-40,0a40,40 0,1 1,80 0a40,40 0,1 1,-80 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="80"
                android:gradientRadius="40"
                android:type="radial">
                <item android:color="#12818CF8" android:offset="0.0" />
                <item android:color="#00818CF8" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Shooting Star (Meteor Detail) -->
    <path
        android:pathData="M85,65 L70,80"
        android:strokeWidth="0.4">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="85"
                android:startY="65"
                android:endX="70"
                android:endY="80"
                android:type="linear">
                <item android:color="#00FFFFFF" android:offset="0.0" />
                <item android:color="#60FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Enhanced Star Field -->
    <path android:fillColor="#ffffff" android:fillAlpha="0.12" android:pathData="M15,75l0.6,0l0,0.6l-0.6,0zM95,90l0.6,0l0,0.6l-0.6,0zM40,100l0.6,0l0,0.6l-0.6,0zM65,85l0.6,0l0,0.6l-0.6,0zM10,95l0.6,0l0,0.6l-0.6,0z" />
    <path android:fillColor="#ffffff" android:fillAlpha="0.3" android:pathData="M25,85l1,0l0,1l-1,0zM80,75l1,0l0,1l-1,0zM55,95l1,0l0,1l-1,0zM92,98l1,0l0,1l-1,0z" />

    <!-- Horizon Glow Accent -->
    <path
        android:pathData="M0,70 Q54,95 108,70 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="108"
                android:gradientRadius="50"
                android:type="radial">
                <item android:color="#12FFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
