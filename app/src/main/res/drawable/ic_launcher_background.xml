    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Day to Dusk Atmospheric Gradient (Restored) -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startY="0"
                android:endY="108"
                android:startX="54"
                android:endX="54"
                android:type="linear">
                <item android:offset="0.0" android:color="#03F8D5" /> <!-- Daytime Blue -->
                <item android:offset="0.5" android:color="#21799D" /> <!-- Indigo Depth -->
                <item android:offset="1.0" android:color="#3F1B5F" /> <!-- Deep Rose Glow (Horizon) -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Rose Horizon Glow -->
    <path
        android:pathData="M0,60 Q54,85 108,60 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="108"
                android:gradientRadius="60"
                android:type="radial">
                <item android:color="#25A43653" android:offset="0.0" />
                <item android:color="#00A43653" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle Evening Stars -->
    <path android:fillColor="#ffffff" android:fillAlpha="0.2" android:pathData="M25,75l0.8,0l0,0.8l-0.8,0zM82,85l0.8,0l0,0.8l-0.8,0zM48,95l0.8,0l0,0.8l-0.8,0zM90,80l0.8,0l0,0.8l-0.8,0z" />
